###Mapping
Mapping demo::PaymentPolymorphicMapping
(
  *demo::payment::CardPayment[cardPayment]: Relational
  {
    ~primaryKey
    (
      [demo::store::PaymentDB]CardPaymentTable.id
    )
    ~mainTable [demo::store::PaymentDB]CardPaymentTable
    reference: [demo::store::PaymentDB]CardPaymentTable.reference,
    amount: [demo::store::PaymentDB]CardPaymentTable.amount,
    cardLast4: [demo::store::PaymentDB]CardPaymentTable.cardLast4
  }

  *demo::payment::BankTransfer[bankTransfer]: Relational
  {
    ~primaryKey
    (
      [demo::store::PaymentDB]BankTransferTable.id
    )
    ~mainTable [demo::store::PaymentDB]BankTransferTable
    reference: [demo::store::PaymentDB]BankTransferTable.reference,
    amount: [demo::store::PaymentDB]BankTransferTable.amount,
    sortCode: [demo::store::PaymentDB]BankTransferTable.sortCode
  }

  *demo::payment::Payment: Operation
  {
    meta::pure::router::operations::inheritance_OperationSetImplementation_1__SetImplementation_MANY_()
  }

  testSuites:
  [
    rootProjectionSuite:
    {
      function: |demo::payment::Payment.all()->sortBy(x|$x.reference)->project([x|$x.reference, x|$x.amount], ['Reference', 'Amount']);
      tests:
      [
        superclassPropertiesAcrossSubtypes:
        {
          data:
          [
            demo::store::PaymentDB:
              Reference
              #{
                demo::data::PaymentData
              }#
          ];
          asserts:
          [
            shouldReturnEveryPayment:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Reference":"PAY-001","Amount":100},{"Reference":"PAY-002","Amount":200},{"Reference":"PAY-003","Amount":300}]';
                  }#;
              }#
          ];
        }
      ];
    },
    downcastSuite:
    {
      function: |demo::payment::Payment.all()->sortBy(x|$x.reference)->project([x|$x.reference, x|$x->subType(@demo::payment::CardPayment).cardLast4], ['Reference', 'Card']);
      tests:
      [
        subtypeSpecificProperty:
        {
          data:
          [
            demo::store::PaymentDB:
              Reference
              #{
                demo::data::PaymentData
              }#
          ];
          asserts:
          [
            shouldDowncastToCardPayment:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Reference":"PAY-001","Card":"4242"},{"Reference":"PAY-002","Card":null},{"Reference":"PAY-003","Card":"1881"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)

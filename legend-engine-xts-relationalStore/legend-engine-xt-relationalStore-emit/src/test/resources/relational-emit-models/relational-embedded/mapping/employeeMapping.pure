###Mapping
Mapping demo::EmbeddedEmployeeMapping
(
  *demo::embedded::Employee: Relational
  {
    ~primaryKey
    (
      [demo::store::EmbeddedDB]EmployeeTable.id
    )
    ~mainTable [demo::store::EmbeddedDB]EmployeeTable
    name: [demo::store::EmbeddedDB]EmployeeTable.name,
    address
    (
      ~primaryKey
      (
        [demo::store::EmbeddedDB]EmployeeTable.addressPostcode
      )
      line1: [demo::store::EmbeddedDB]EmployeeTable.addressLine1,
      postcode: [demo::store::EmbeddedDB]EmployeeTable.addressPostcode
    )
  }

  testSuites:
  [
    embeddedSuite:
    {
      function: |demo::embedded::Employee.all()->sortBy(x|$x.name)->project([x|$x.name, x|$x.address.line1, x|$x.address.postcode], ['Name', 'Line1', 'Postcode']);
      tests:
      [
        embeddedAddress:
        {
          data:
          [
            demo::store::EmbeddedDB:
              Reference
              #{
                demo::data::EmbeddedEmployeeData
              }#
          ];
          asserts:
          [
            shouldEmbed:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Jane Smith","Line1":"2 High St","Postcode":"20002"},{"Name":"John Doe","Line1":"1 Main St","Postcode":"10001"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)

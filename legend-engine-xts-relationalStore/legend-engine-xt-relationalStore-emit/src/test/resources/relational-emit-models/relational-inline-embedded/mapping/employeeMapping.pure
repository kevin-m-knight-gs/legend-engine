###Mapping
Mapping demo::InlineEmbeddedEmployeeMapping
(
  demo::inline::Address[addressAlias]: Relational
  {
    line1: [demo::store::InlineEmbeddedDB]EmployeeTable.addressLine1,
    postcode: [demo::store::InlineEmbeddedDB]EmployeeTable.addressPostcode
  }

  *demo::inline::Employee[employeeAlias]: Relational
  {
    ~primaryKey
    (
      [demo::store::InlineEmbeddedDB]EmployeeTable.id
    )
    ~mainTable [demo::store::InlineEmbeddedDB]EmployeeTable
    name: [demo::store::InlineEmbeddedDB]EmployeeTable.name,
    address () Inline [addressAlias]
  }

  testSuites:
  [
    inlineEmbeddedSuite:
    {
      function: |demo::inline::Employee.all()->sortBy(x|$x.name)->project([x|$x.name, x|$x.address.line1, x|$x.address.postcode], ['Name', 'Line1', 'Postcode']);
      tests:
      [
        inlinedAddress:
        {
          data:
          [
            demo::store::InlineEmbeddedDB:
              Reference
              #{
                demo::data::InlineEmbeddedEmployeeData
              }#
          ];
          asserts:
          [
            shouldInline:
              EqualToJson
              #{
                expected:
                  ExternalFormat
                  #{
                    contentType: 'application/json';
                    data: '[{"Name":"Jane Smith","Line1":"2 High St","Postcode":"20002"},{"Name":"John Doe","Line1":"1 Main St","Postcode":"10001"}]';
                  }#;
              }#
          ];
        }
      ];
    }
  ]
)
